# Environment Configuration for Co-Buddy
# Copy this file to .env and fill in your actual values

# Application Environment
NODE_ENV=development
PORT=3000

# NVIDIA NIM Configuration
VITE_NVIDIA_NIM_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_NIM_API_KEY=your_nvidia_api_key_here

# Database Configuration (MySQL/PostgreSQL)
DATABASE_URL=mysql://username:password@localhost:3306/cobuddy
# For PostgreSQL use: postgresql://username:password@localhost:5432/cobuddy

# Analytics (Optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_make_it_long_and_random

# File Upload Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name_here

# Development Only
MANUS_ENVIRONMENT=false

# Platform Specific Configuration
# Windows: Use forward slashes in paths
# Linux/Mac: Use native paths
# Android: Use relative paths where possible
