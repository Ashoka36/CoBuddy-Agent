# Multi-Agent System Environment Variables
# Live Test Configuration

# AI Provider API Keys (Required for anti-loop fallback system)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Remote Execution Endpoints (Optional - defaults will be used if not set)
FLUTTER_API_ENDPOINT=https://api.flutter.dev
FAISS_API_ENDPOINT=https://faiss-api.example.com
PEFT_API_ENDPOINT=https://peft-api.example.com
SENTENCE_TRANSFORMERS_API_ENDPOINT=https://embeddings-api.example.com

# YODDA Configuration
SECRET_KEY=co_buddy_secret_key_live_test_2024
DB_PATH=cobuddy_memory.db

# Server Ports (Optional - can be changed to avoid conflicts)
YODDA_PORT=8000
GIFFY_PORT=8080
AEGIS_PORT=8001
COBUDDY_PORT=8002

# Security Settings
CORS_ORIGINS=*
ENVIRONMENT=development

# Memory and Performance
MAX_MEMORY_USAGE=0.7
BATCH_SIZE=32
CHUNK_SIZE=512
MAX_CONCURRENT_REQUESTS=5
